# QWEN_CLOUD_API_KEY - Your Qwen Cloud API key from https://bit.ly/qwencloud-getapi
QWEN_API_KEY=your_qwen_cloud_api_key_here

# QWEN_MODEL - The Qwen model to use for reasoning
QWEN_MODEL=qwen-plus

# QWEN_BASE_URL - DashScope OpenAI-compatible endpoint
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ALIBABA_CLOUD - CloudMonitor / ECS credentials
ALIBABA_ACCESS_KEY_ID=your_alibaba_access_key_id
ALIBABA_ACCESS_KEY_SECRET=your_alibaba_access_key_secret
ALIBABA_REGION=us-east-1

# GITHUB - For PR generation
GITHUB_TOKEN=your_github_token
GITHUB_REPO_OWNER=your_github_username
GITHUB_REPO_NAME=your_repo_name

# APP CONFIG
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=https://cloudsense.lamine-gaye.tech

# DATABASE (optional - for persistent anomaly history)
DATABASE_URL=sqlite:///./cloudsense.db

# VPS DEPLOYMENT CONFIG
BACKEND_DOMAIN=cloudsense.yourdomain.com
TRAEFIK_NETWORK=traefik-public
CERT_RESOLVER=myresolver

